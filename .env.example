# Copy this file to .env and fill in your values
# .env is gitignored — never commit it
#
# Both the dev stack (docker-compose.dev.yml) and prod stack (docker-compose.prod.yml)
# read from this same .env file. Each stack uses its own isolated database:
#   dev  → jobmatcher_dev
#   prod → jobmatcher_prod
# The POSTGRES_DB value below is unused by the compose files (each hardcodes its DB
# name), but is kept for reference and legacy compatibility.

POSTGRES_USER=jobmatcher
POSTGRES_PASSWORD=your-strong-password-here  # generate with: openssl rand -base64 32
POSTGRES_DB=jobmatcher

# APP_VERSION is set automatically by the deploy workflow (short git SHA).
# Override locally if needed; defaults to "local" when unset.
APP_VERSION=
