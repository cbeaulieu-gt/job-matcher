# NOTE: This file is superseded by .env.dev.example and .env.prod.example for the
# Docker deployment path. Use those files instead:
#   .env.dev.example  → copy to .env.dev  (used by docker-compose.dev.yml)
#   .env.prod.example → copy to .env.prod (used by docker-compose.prod.yml)
#
# This file is retained for legacy / non-Docker local usage only.
# Copy to .env and fill in your values. .env is gitignored — never commit it.

POSTGRES_USER=jobmatcher
POSTGRES_PASSWORD=your-strong-password-here  # generate with: openssl rand -base64 32
POSTGRES_DB=jobmatcher

# APP_VERSION is set automatically by the deploy workflow (short git SHA).
# Override locally if needed; defaults to "local" when unset.
APP_VERSION=
